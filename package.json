{
  "name": "axona-share",
  "version": "0.14.1",
  "description": "Share images over Axona pub/sub — a small reference app for the Axona protocol.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx --yes http-server -p 8080 -c-1 .",
    "link-kernel": "npm install && ln -sfn node_modules/@axona/protocol axona-protocol"
  },
  "dependencies": {
    "@axona/protocol": "github:axona-net/axona-protocol#v4.38.0"
  }
}
